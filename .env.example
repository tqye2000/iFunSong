# Optional: server-side OpenAI key. You can also enter a key in the browser UI.
OPENAI_API_KEY=

# Optional: timestamp-capable OpenAI transcription model.
# The app defaults to whisper-1 because it supports verbose JSON segment timestamps.
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Files larger than this are compressed to MP3 before OpenAI transcription.
OPENAI_DIRECT_AUDIO_MAX_BYTES=25165824

# Optional: if your network requires a proxy for HTTPS requests.
# HTTPS_PROXY=http://user:password@proxy-host:proxy-port
HTTPS_PROXY=

# Recommended fix for "unable to get local issuer certificate":
# export your proxy/antivirus/company root certificate as a PEM file and point Node at it.
# NODE_EXTRA_CA_CERTS=C:\path\to\company-root-ca.pem
NODE_EXTRA_CA_CERTS=

# Last-resort local testing only. This disables TLS certificate verification for outbound OpenAI requests.
# Do not use this for anything sensitive.
OPENAI_TLS_REJECT_UNAUTHORIZED=true

# Optional: OpenAI request timeout in milliseconds.
OPENAI_REQUEST_TIMEOUT_MS=600000

# Optional: override bundled binaries.
FFMPEG_PATH=
FFPROBE_PATH=

# Optional: local transcription fallback.
# The command must write JSON to {output}, with either:
#   { "text": "...", "segments": [{ "start": 0.0, "end": 3.5, "text": "..." }] }
# or:
#   { "segments": [{ "startMs": 0, "endMs": 3500, "text": "..." }] }
# Quote placeholders if your paths contain spaces.
LOCAL_TRANSCRIPTION_COMMAND=
